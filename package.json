{
  "name": "rbac-admin-pro",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @rbac-admin-pro/web run dev & pnpm --filter server-nestjs run start:dev",
    "dev:web": "pnpm --filter @rbac-admin-pro/web run dev",
    "dev:server": "pnpm --filter server-nestjs run start:dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @rbac-admin-pro/web run build",
    "build:server": "pnpm --filter server-nestjs run build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "type-check": "pnpm --filter @rbac-admin-pro/web run type-check",
    "validate": "pnpm --filter server-nestjs run validate",
    "db:migrate": "pnpm --filter server-nestjs exec prisma migrate dev",
    "db:generate": "pnpm --filter server-nestjs exec prisma generate",
    "db:seed": "pnpm --filter server-nestjs exec prisma db seed",
    "db:studio": "pnpm --filter server-nestjs exec prisma studio"
  },
  "devDependencies": {
    "shadcn-vue": "^2.4.1"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
