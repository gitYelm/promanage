# Docker Compose 环境变量配置
#
# 使用方法（二选一）:
# 方式一（推荐）: cp .env.docker.example .env && docker-compose up -d
# 方式二: cp .env.docker.example .env.docker && docker-compose --env-file .env.docker up -d

# ==================== 数据库配置 ====================
POSTGRES_DB=rbac_admin_pro
POSTGRES_USER=rbac_admin
# 请修改为强密码！
POSTGRES_PASSWORD=YourStrongPassword@2024

# ==================== JWT 配置 ====================
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=723a5e240b42882d517ea76b8ff262ea17de90d8065e69af71ffc0ddf8dccae6

# ==================== Redis 配置 ====================
# Docker 环境默认启用 Redis（有 redis 容器）
# 如需禁用设为 false，将使用内存模式
REDIS_ENABLED=true

# ==================== CORS 配置 ====================
# 允许的跨域来源，控制跨域请求和 iframe 嵌入权限
#
# 部署场景说明：
# - 同域部署（nginx 反向代理，前后端同域名）：无需配置，默认 'self' 即可
# - 跨域部署（前后端分离域名）：必须配置前端域名
#
# 格式：多个来源用逗号分隔
# 示例：https://admin.example.com,https://www.example.com
CORS_ORIGINS=